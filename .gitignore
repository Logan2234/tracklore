# Dependencies
node_modules/

# Builds
dist/
build/
.svelte-kit/

# Environment — never commit secrets
.env
.env.*
!.env.example

# Generated docs (prisma-erd-generator output; regenerated on prisma generate OR modules.md for NestJS modules)
docs/*
!docs/.gitkeep

# Local dev backups (admin "Sauvegarde" default BACKUP_DIR; self-host uses a Docker volume instead)
apps/api/backups/

# Logs & caches
*.log
.turbo/
coverage/

# OS / editors
.DS_Store
Thumbs.db

# Claude Code worktrees (created/removed by the harness, not repo content)
.claude/worktrees/

ngrok.yml
