# --- Database ---
POSTGRES_USER=tracklore
POSTGRES_PASSWORD=change-me
POSTGRES_DB=tracklore

# --- API secrets (generate long random strings, e.g. `openssl rand -hex 32`) ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

# --- External catalogues ---
# TMDB API Read Access Token (v4), free account: https://www.themoviedb.org/settings/api
# Without it, movie/series search fails; anime (AniList) works without any key.
TMDB_API_TOKEN=


# Optional: OMDb key for IMDb/Rotten Tomatoes/Metacritic scores (https://www.omdbapi.com/apikey.aspx).
# Empty = those ratings are omitted (TMDB/AniList scores still show).
OMDB_API_KEY=


# IGDB games catalogue via a Twitch app (https://dev.twitch.tv/console/apps).
# Empty = game search/details fail; movies/series/anime are unaffected.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=


# Steam Web API key (https://steamcommunity.com/dev/apikey) for the Steam import.
STEAM_API_KEY=


# Optional: Google Books key (enable "Books API" in a Google Cloud project, then
# create an API key). Set = books use Google Books first (richer data), falling
# back to Open Library. Empty = books use Open Library only (keyless).
GOOGLE_BOOKS_API_KEY=


# --- Networking (defaults fit a local/NAS install) ---
# Port the API is exposed on, and the URL the browser uses to reach it.
API_PORT=3000
PUBLIC_API_URL=http://localhost:3000/api


# Port the web app is exposed on, and its origin (for API CORS).
WEB_PORT=8080
WEB_ORIGIN=http://localhost:8080


# --- Mobile access via ngrok (see README "Mobile access") ---
# Only used with the docker-compose.ngrok.yml override (Caddy reverse proxy).
# Just your ngrok static domain — the override derives PUBLIC_API_URL,
# WEB_ORIGIN and PUBLIC_NGROK from it, so you set it in one place.
NGROK_DOMAIN=your-domain.ngrok-free.app
# Host port the Caddy single-origin proxy listens on; ngrok points here.
PROXY_PORT=8088
