NODE_ENV=development


# CORS origin for the web client 
WEB_ORIGIN=http://localhost:5173


# Local development (see docker-compose.yml for self-hosting).
DATABASE_URL="postgresql://tracklore:tracklore@localhost:5433/tracklore?schema=public"
JWT_ACCESS_SECRET="dev-only-change-me-access"
JWT_REFRESH_SECRET="dev-only-change-me-refresh"


# HTTPS
API_TLS_KEY="certs/localhost-key.pem"
API_TLS_CERT="certs/localhost.pem"


# Outgoing email (password reset, email verification, change confirmations,
# new-episode alerts). Empty = email is silently disabled, everything else
# still works. Brevo (https://www.brevo.com) has a free SMTP relay (300/day):
# create an account, then "SMTP & API" in the sidebar for these values.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Tracklore <no-reply@tracklore.app>"


# TMDB API Read Access Token (v4): https://www.themoviedb.org/settings/api
TMDB_API_TOKEN=""


# Optional: OMDb key for IMDb/Rotten Tomatoes/Metacritic scores (https://www.omdbapi.com/apikey.aspx).
# Empty = those ratings are simply omitted (TMDB/AniList scores still show).
OMDB_API_KEY=""


# IGDB (games catalogue). Create a Twitch application at
# https://dev.twitch.tv/console/apps — IGDB authenticates through a Twitch
# app-access token. Empty = game search/details fail at runtime (media is
# unaffected). Unit tests stub all HTTP, so they pass without these.
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""


# Steam Web API key (https://steamcommunity.com/dev/apikey), for the Steam
# library import. Empty = the Steam import fails at runtime; nothing else needs it.
STEAM_API_KEY=""


# Required: Google Books API key (enable "Books API" in a Google Cloud project,
# then create an API key). Google Books is the only book source — empty means
# book search/import fails at runtime.
GOOGLE_BOOKS_API_KEY=""


