generator client {
  provider = "prisma-client-js"
}

// Dev-only: renders an entity-relationship diagram of the schema as a Mermaid
// markdown file (viewable in GitHub/VS Code). Skipped in the Docker build via
// DISABLE_ERD so it never runs in prod. The .md target avoids the headless
// Chromium that the SVG/PNG targets require.
generator erd {
  provider = "prisma-erd-generator"
  output   = "../../../docs/erd.md"
}

datasource db {
  provider = "postgresql"
}

enum MediaType {
  MOVIE
  SERIES
  ANIME
}

// Top-level content domain a user can compose their app from. MEDIA groups
// MOVIE/SERIES/ANIME; BOOKS/GAMES/MUSIC each have their own screens (search,
// library, stats). `User.enabledDomains` drives the nav (see web isDomainEnabled).
// PODCASTS/BOARDGAMES are planned P3 placeholders — no backing tables yet,
// surfaced as "coming soon" and kept out of the enabledDomains default (opt-in).
enum Domain {
  MEDIA
  BOOKS
  GAMES
  MUSIC
  PODCASTS
  BOARDGAMES
}

// Operational permission level, orthogonal to User.entitlements (the future
// paid-tier seam). See packages/shared/src/enums.ts Role for the rationale.
enum Role {
  USER
  ADMIN
}

// --- Social (P4) — all gated behind the runtime SOCIAL_ENABLED flag. ---
// Mirror of packages/shared/src/enums.ts; see there for the full rationale.

// How reachable a profile is (the authN layer). Caps the per-facet audience.
enum ProfileAccess {
  PUBLIC
  PRIVATE
  GHOST // "Figurant": invisible but can participate anonymously.
}

// Who may see a passive-content facet (the authZ layer). NONE < FRIENDS < PUBLIC.
enum VisibilityAudience {
  PUBLIC
  FRIENDS
  NONE
}

// Passive-content facets tuned per domain. Coarse on purpose (splittable later).
enum VisibilityFacet {
  LIBRARY // presence + status + progress + favorites
  ACTIVITY // appearance in the activity feed
}

// State of a directed follow. A follow of a PUBLIC profile is created ACCEPTED
// immediately; a follow of a PRIVATE profile starts PENDING until approved.
enum FollowStatus {
  PENDING
  ACCEPTED
}

// What a review targets. Works (MEDIA/GAME/BOOK/MUSIC) plus finer media levels.
enum ReviewTargetType {
  MEDIA
  SEASON
  EPISODE
  GAME
  BOOK
  MUSIC
}

// A review's audience (no PRIVATE — a review is at least FRIENDS). Only felt
// when social is enabled.
enum ReviewVisibility {
  FRIENDS
  PUBLIC
}

// What a comment thread targets. Same shape as ReviewTargetType (a comment
// under a work, or one of its seasons/episodes).
enum CommentTargetType {
  MEDIA
  SEASON
  EPISODE
  GAME
  BOOK
  MUSIC
}

// Fixed reaction set for comments (backlog: a full emoji picker). Display
// glyphs live in shared code (COMMENT_EMOTE_DISPLAY) — this enum stores the
// identifier, not the glyph.
enum CommentEmote {
  LIKE
  LOVE
  LAUGH
  WOW
  SAD
  DISLIKE
}

// What a report targets. COMMENT is the only kind produced today; REVIEW/USER
// are modelled now so a future "report a review/profile" needs no migration.
enum ReportTargetType {
  COMMENT
  REVIEW
  USER
  LIST
}

// A list's kind: RANKED shows explicit rank order (drag-to-reorder, "top 10"),
// COLLECTION is an unordered grid. Same storage (ListItem + position) either way.
enum ListKind {
  RANKED
  COLLECTION
}

// A list's own explicit audience (mirrors Review's own-scope pattern, not the
// per-domain VisibilitySetting facets — a list isn't tied to one domain).
// Unlike ReviewVisibility, PRIVATE exists: a list defaults to it.
enum ListVisibility {
  PRIVATE
  FRIENDS
  PUBLIC
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

// Sources we actually fetch from (canonical).
enum CatalogSource {
  TMDB
  ANILIST
}

// All sources an external ID can come from. TVDB/IMDB are secondary
// identifiers kept for reconciliation (e.g. TV Time import) and deduplication.
enum ExternalSource {
  TMDB
  ANILIST
  TVDB
  IMDB
}

enum EntryStatus {
  WATCHING
  COMPLETED
  PLANNED
  DROPPED
  // Series/anime: everything released is watched but the show is still airing.
  // Never stored — it is a derived, read-time status (see LibraryService).
  UP_TO_DATE
}

// How the user holds a movie/series/anime, if at all. NONE (default) means
// unset — most entries never get this filled in. DIGITAL/STREAMING carry a
// free-form `ownershipSource` (e.g. "Netflix", "Apple TV"); PHYSICAL/BORROWED
// don't need one.
enum MediaOwnershipStatus {
  NONE
  PHYSICAL
  DIGITAL
  STREAMING
  BORROWED
}

// Source a game's catalogue data comes from. IGDB is the only one today.
enum GameSource {
  IGDB
}

// A game's library status. Unlike EntryStatus it is entirely user-set: games
// have no per-episode progress to derive "playing"/"completed" from.
enum GameStatus {
  BACKLOG
  PLAYING
  COMPLETED
  DROPPED
}

// How the user holds a game, if at all. NONE (default) means unset. DIGITAL
// carries a free-form `ownershipSource` (e.g. "Steam"), SUBSCRIPTION too (e.g.
// "Xbox Game Pass"); PHYSICAL/BORROWED don't need one.
enum GameOwnershipStatus {
  NONE
  PHYSICAL
  DIGITAL
  SUBSCRIPTION
  BORROWED
}

// Source a book's catalogue data comes from. Google Books only — Open Library
// was dropped in favour of a single, more reliable data source.
enum BookSource {
  GOOGLE_BOOKS
}

// A book's library status. Like GameStatus it is entirely user-set; page
// progress is tracked separately on the entry. TO_READ doubles as the wishlist.
enum BookStatus {
  TO_READ
  READING
  READ
  DROPPED
}

// How the user holds a book, if at all. NONE (default) means unset. DIGITAL
// carries a free-form `ownershipSource` (e.g. "Kindle"), AUDIO too (e.g.
// "Audible"); PHYSICAL/BORROWED don't need one.
enum BookOwnershipStatus {
  NONE
  PHYSICAL
  DIGITAL
  AUDIO
  BORROWED
}

// Source a music item's catalogue data comes from. MusicBrainz only.
enum MusicSource {
  MUSICBRAINZ
}

// An album's library status. Deliberately binary, unlike GameStatus/
// BookStatus: an album listen is a short, single-session event, so there is
// no "in progress" or "dropped" state. TO_LISTEN doubles as the wishlist.
enum MusicStatus {
  TO_LISTEN
  LISTENED
}

// How the user holds an album, if at all. NONE (default) means unset.
// DIGITAL/STREAMING carry a free-form `ownershipSource` (e.g. "Bandcamp",
// "Spotify"); PHYSICAL/BORROWED don't need one.
enum MusicOwnershipStatus {
  NONE
  PHYSICAL
  DIGITAL
  STREAMING
  BORROWED
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  // Free-form label shown around the app; not unique. See `username` for the
  // unique, login-capable handle.
  displayName       String
  // Unique login handle (alongside email). Assigned at registration, editable
  // in Sécurité.
  username          String    @unique
  birthDate         DateTime?
  // Opt-in to 18+ titles; only effective when birthDate proves the account is 18+.
  allowAdultContent Boolean   @default(false)
  // Communication preferences: which channels deliver "new episode" alerts.
  notifyInApp       Boolean   @default(true)
  notifyEmail       Boolean   @default(false)
  notifyPush        Boolean   @default(false)
  // Set once the verification email's link has been opened. Informational only
  // in self-host (no feature is gated on it) — see UserToken.
  emailVerified     Boolean   @default(false)
  // Free-form public bio shown on the social profile (P4). Null until set.
  bio               String?
  // Social (P4): how reachable this profile is. Default PRIVATE — the safe
  // default (nothing exposed to the public without an accepted follow). The
  // per-domain/facet audiences live in VisibilitySetting.
  profileAccess     ProfileAccess @default(PRIVATE)
  // Default audience applied to a new review unless overridden at publication.
  defaultReviewVisibility ReviewVisibility @default(FRIENDS)
  // Default audience applied to a new list unless overridden at creation.
  defaultListVisibility ListVisibility @default(PRIVATE)
  // Open-core seam: feature flags granted to this user (empty in self-host MVP).
  // NOT used for admin permission — see `role` below.
  entitlements      Json      @default("[]")
  // Operational permission level (gates /admin). Separate axis from
  // `entitlements` (paid tier): an admin isn't "the highest tier".
  role              Role      @default(USER)
  // Composition seam: content domains the user enabled. Drives the nav today;
  // search/notif filtering follow at P3. Default = every domain visible.
  enabledDomains    Domain[]  @default([MEDIA, BOOKS, GAMES, MUSIC])
  // Ordered ids of the mobile bottom-bar shortcuts (see web navigation.ts,
  // `MobileNavId`). Free-form strings, not a Prisma enum: the set is a web-UI
  // concern (includes the "menu" launcher and non-domain routes), gated at
  // render time. Default mirrors DEFAULT_BOTTOM_SHORTCUTS.
  mobileNavShortcuts String[] @default(["home", "search", "menu", "calendar", "account"])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  entries             LibraryEntry[]
  episodeWatches      EpisodeWatch[]
  refreshTokens       RefreshToken[]
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  gameEntries         GameEntry[]
  bookEntries         BookEntry[]
  musicEntries        MusicEntry[]
  tokens              UserToken[]
  emailChangeRequests EmailChangeRequest[]
  securityEvents      SecurityEvent[]
  importRuns          ImportRun[]
  visibilitySettings  VisibilitySetting[]
  following           Follow[]             @relation("UserFollowing")
  followers           Follow[]             @relation("UserFollowers")
  blocking            Block[]              @relation("UserBlocking")
  blockedBy           Block[]              @relation("UserBlockedBy")
  reviews             Review[]
  activityEvents      ActivityEvent[]
  comments            Comment[]
  commentReactions    CommentReaction[]
  reportsFiled        Report[]             @relation("ReportsFiled")
  reportsResolved     Report[]             @relation("ReportsResolved")
  lists               List[]
}

// Social (P4): per-user, per-domain, per-facet audience. One row overrides the
// coded default (FRIENDS) for a (domain, facet) pair; absence = default. Only
// the two passive-content facets are stored here — reviews carry their own
// scope and comments are public by nature. Effective visibility is still capped
// by User.profileAccess at read time.
model VisibilitySetting {
  id       String             @id @default(cuid())
  userId   String
  domain   Domain
  facet    VisibilityFacet
  audience VisibilityAudience
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain, facet])
}

// Social (P4): directed follow edge. `followerId` follows `followeeId`.
// Friendship (the "Amis" audience) is a reciprocal pair of ACCEPTED follows.
// On a PRIVATE followee the edge is PENDING until the followee approves it;
// an accepted follow of a PRIVATE profile grants friend-level visibility
// (Instagram-style approval), while on a PUBLIC profile friend-level requires
// the follow to be mutual. See VisibilityService.
model Follow {
  id         String       @id @default(cuid())
  followerId String
  followeeId String
  status     FollowStatus
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  follower   User         @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  followee   User         @relation("UserFollowers", fields: [followeeId], references: [id], onDelete: Cascade)

  @@unique([followerId, followeeId])
  @@index([followeeId, status])
}

// Social (P4): a hard block. Removes any follow edges between the two, prevents
// re-following and content access, and neutralizes comments/mentions from the
// blocked user. Directed: `blockerId` blocked `blockedId`.
model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("UserBlocking", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("UserBlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

// Social (P4): the single source of truth for a user's /10 rating on a target
// (a work, or a media season/episode). Rating is mandatory, text optional.
// Editing your own review always works (even with social off — it's your
// rating); reading others' and the FRIENDS/PUBLIC audience are social-gated.
// One review per (user, target); edits are historised in ReviewRevision.
// targetId is not a FK (polymorphic across item/season/episode tables).
model Review {
  id         String           @id @default(cuid())
  userId     String
  targetType ReviewTargetType
  targetId   String
  rating     Float
  text       String?
  visibility ReviewVisibility @default(FRIENDS)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  revisions  ReviewRevision[]

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}

// One immutable snapshot per review edit (V1, V2, …), newest by createdAt.
model ReviewRevision {
  id        String   @id @default(cuid())
  reviewId  String
  rating    Float
  text      String?
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId, createdAt])
}

// Social (P4): a comment/reply on an item (work, season or episode —
// CommentTargetType mirrors ReviewTargetType). Flat + one reply level: a
// reply's parentId always points at a top-level comment (never chained), the
// UI enforces this by only offering "reply" on top-level comments. Deletion is
// soft (text cleared, deletedAt set) so replies stay attached and readable —
// hard-deleting a parent would orphan or lose the whole sub-thread.
model Comment {
  id         String            @id @default(cuid())
  targetType CommentTargetType
  targetId   String
  authorId   String
  parentId   String?
  text       String?
  // Author-set manual spoiler tag. Combined at read time with the auto
  // progression-based gate (see CommentService) into a per-viewer "masked"
  // hint — the raw tag itself is what the edit form prefills.
  spoilerTag Boolean           @default(false)
  edited     Boolean           @default(false)
  deletedAt  DateTime?
  // Set only by admin takedown (adminRemove) — distinguishes the tombstone
  // shown to readers ("supprimé par un administrateur" vs the author's own
  // "supprimé").
  deletedByAdmin Boolean       @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  author    User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]         @relation("CommentReplies")
  reactions CommentReaction[]

  @@index([targetType, targetId, createdAt])
  @@index([parentId])
}

// One active reaction per (user, comment) — posting a new emote replaces it
// (upsert on the unique pair), not a multi-emote-per-user model.
model CommentReaction {
  id        String       @id @default(cuid())
  commentId String
  userId    String
  emote     CommentEmote
  createdAt DateTime     @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

// Social (P4): a user-submitted report against a polymorphic target — a
// comment today, extensible to reviews/profiles later without a new table
// (targetType/targetId, same pattern as Review/ActivityEvent). Feeds the admin
// moderation queue (/admin/reports). targetId is not a FK (polymorphic).
model Report {
  id           String           @id @default(cuid())
  targetType   ReportTargetType
  targetId     String
  reporterId   String
  reason       String?
  status       ReportStatus     @default(PENDING)
  createdAt    DateTime         @default(now())
  resolvedAt   DateTime?
  resolvedById String?

  reporter   User  @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("ReportsResolved", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

// Social (P4): a cross-domain, user-curated list of works (RANKED "top 10" or
// an unordered COLLECTION). Own explicit visibility, like Review — never
// inherited from the per-domain VisibilitySetting facets. Managing your own
// lists works even with social off (mirrors Review's own-CRUD-ungated split);
// only reading someone else's shared list is social-gated.
model List {
  id          String         @id @default(cuid())
  userId      String
  title       String
  description String?
  kind        ListKind
  visibility  ListVisibility @default(PRIVATE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ListItem[]

  @@index([userId])
}

// One work in a list, work-level only (no season/episode — narrower than
// ReviewTargetType/CommentTargetType, whose enum is reused as-is; SEASON/
// EPISODE values are rejected at the DTO layer). `position` is a dense
// 0..n-1 index rewritten wholesale on reorder (solo-owned lists, no
// concurrent-edit concern).
model ListItem {
  id         String           @id @default(cuid())
  listId     String
  targetType ReviewTargetType
  targetId   String
  position   Int
  addedAt    DateTime         @default(now())

  list List @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, targetType, targetId])
  @@index([listId, position])
}

// One row per browser/device push subscription (Web Push). endpoint is the
// natural unique key: re-subscribing the same device updates its keys in place.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// In-app notifications (currently only "new episode out" of a tracked show).
// Payload is denormalised so a notification survives catalogue-cache refreshes.
// Generic in-app notification. Kinds ("NEW_EPISODE", "FOLLOW",
// "FOLLOW_REQUEST", "FOLLOW_ACCEPTED"…) share one shape: a title, an optional
// body/link, and a `data` bag for kind-specific display extras (episode airDate,
// the social actor's username/avatar seed…). A string `type` means new kinds
// need no migration.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String    @default("NEW_EPISODE")
  title     String
  body      String?
  // Client-side deep link (e.g. /media/movie/42 or /u/alice).
  url       String?
  // Stable idempotency key so re-scans / re-follows don't duplicate a row:
  //   "episode:<episodeId>", "follow:<actorId>", "request:<actorId>",
  //   "accept:<actorId>". Null means "never deduped".
  dedupeKey String?
  // Kind-specific extras. For NEW_EPISODE: { airDate }. For social kinds:
  // { actorUsername, actorDisplayName } (drives the Avatar + name in the feed).
  data      Json      @default("{}")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, createdAt])
}

// Social (P4): materialised activity feed. Append-only log of a user's actions
// (started/finished/rated a work…). Two surfaces read from it: the home feed
// (followed users, `homeFeed = true` milestones only) and a user's profile
// timeline (everything, gated by their Activité visibility). The target work is
// denormalised (title/imageUrl/href) so a feed page needn't fan out across the
// four domain tables on every read. `data` carries kind-specific extras
// (rating, episode code, aggregation count).
model ActivityEvent {
  id         String   @id @default(cuid())
  // The actor.
  userId     String
  // ActivityType: ADDED, STARTED, FINISHED, DROPPED, REWATCHED, PROGRESS,
  // FAVORITED, REVIEWED. A string so new kinds need no migration.
  type       String
  // Domain enum value (MEDIA/GAMES/BOOKS/MUSIC) — used to gate the profile
  // timeline against the actor's Activité audience for that domain.
  domain     String
  // Polymorphic work: ReviewTargetType-style ("MEDIA"/"GAME"/"BOOK"/"MUSIC")
  // + the internal item id.
  targetType String
  targetId   String
  // WORK / SEASON / EPISODE — the granularity, per the feed matrix.
  level      String   @default("WORK")
  // Whether this event surfaces on followers' home feed (matrix milestone).
  homeFeed   Boolean  @default(false)
  // Denormalised display snapshot of the target at emit time.
  title      String
  imageUrl   String?
  href       String?
  // Kind-specific extras: { rating } for REVIEWED, { seasonNumber, episodeNumber }
  // for PROGRESS, etc.
  data       Json     @default("{}")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Home feed: recent events of followed users, filtered on homeFeed.
  @@index([userId, createdAt])
  @@index([homeFeed, createdAt])
}

// One row per execution of a scheduled/admin-triggered job (notification scan,
// media refresh…), for the admin "Jobs & tâches" page. Pruned to the last 50
// rows per jobKey at write time (see JobRunService) so the table stays bounded
// on a self-host instance running for years.
model JobRun {
  id         String   @id @default(cuid())
  // Stable identifier, e.g. "notifications.scan", "media.refreshStale".
  jobKey     String
  startedAt  DateTime
  finishedAt DateTime
  status     String
  // Short human summary of the outcome, e.g. "12 notification(s) créée(s)".
  summary    String?
  // Present only when status is "FAILURE".
  error      String?

  @@index([jobKey, startedAt])
}

// One row per device/session, so refreshing on the phone does not log out the desktop.
// The row survives token rotation (only tokenHash/jti/lastUsedAt change), so it
// models a durable "connected device" — see auth.service refresh().
model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  // Refresh-JWT id (payload `jti`); lets the current device be flagged in the
  // sessions list without transmitting the token itself.
  jti        String   @unique
  // Raw User-Agent captured at sign-in, to label the device in the UI.
  userAgent  String?
  expiresAt  DateTime
  // Bumped on every rotation — the session's "last active" timestamp.
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum UserTokenType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
}

// One-time links mailed to the user (password reset, email verification):
// same shape (a hashed token + an expiry), so both share a row via `type`. A
// fresh request invalidates the previous one of the same type (see
// AuthService.requestPasswordReset / .register). The raw token is only ever
// mailed as a link (MailService) — its hash is what's stored here.
model UserToken {
  id        String        @id @default(cuid())
  userId    String
  type      UserTokenType
  tokenHash String        @unique
  expiresAt DateTime
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

enum SecurityEventType {
  USER_REGISTERED
  USER_DELETED
  EMAIL_CHANGED
  PASSWORD_CHANGED
  PASSWORD_RESET
  LOGIN_FAILED
}

// One sensitive account action, for the admin "Sécurité" page. userId is
// nullable + onDelete: SetNull (not Cascade) so the trail survives account
// deletion — USER_DELETED itself would otherwise vanish the instant it's
// written. `identifier` is denormalised for the same reason, and also covers
// LOGIN_FAILED against an unknown email/username (no userId to attach).
model SecurityEvent {
  id         String            @id @default(cuid())
  type       SecurityEventType
  userId     String?
  identifier String
  detail     String?
  userAgent  String?
  createdAt  DateTime          @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([userId])
}

// One committed import (tvtime/storygraph/goodreads/steam), for the admin
// "Imports" audit log. Analyze-only runs write nothing and aren't logged.
// userId is nullable + onDelete: SetNull and identifier is denormalised —
// mirrors SecurityEvent, so the trail survives account deletion.
model ImportRun {
  id         String   @id @default(cuid())
  userId     String?
  identifier String
  sourceId   String
  status     String
  // Items actually written (the user's kept selection), regardless of outcome.
  itemCount  Int
  overwrite  Boolean  @default(false)
  // Human summary joined from the report's tiles; null on failure.
  summary    String?
  // Present only when status is "FAILURE".
  error      String?
  startedAt  DateTime
  finishedAt DateTime

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sourceId, startedAt])
  @@index([userId])
}

// One row per external provider per UTC day — the raw series the /admin/services
// page aggregates into "today" and "this month" depending on each provider's
// documented quota window. Unbounded (like SecurityEvent/ImportRun): a few
// rows per provider per day is negligible volume.
model ApiCallCounter {
  id       String   @id @default(cuid())
  provider String
  day      DateTime
  count    Int      @default(0)

  @@unique([provider, day])
  @@index([provider])
}

// One pending email change per row; a fresh request invalidates the previous
// one (see UsersController.changeEmail). The new address only replaces
// User.email once its code is confirmed (UsersController.confirmEmailChange).
model EmailChangeRequest {
  id        String   @id @default(cuid())
  userId    String
  newEmail  String
  codeHash  String   @unique
  // Failed confirm attempts; the request is deleted after 5 (see
  // MAX_EMAIL_CHANGE_ATTEMPTS) to bound brute-forcing the 6-digit code.
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// On-demand cache: a media exists here only once at least one user references it.
// Search results are served live from TMDB/AniList and never persisted.
model MediaItem {
  id              String        @id @default(cuid())
  type            MediaType
  canonicalSource CatalogSource
  title           String
  posterUrl       String?
  backdropUrl     String?
  overview        String?
  releaseDate     DateTime?
  // Airing status as reported by the source (free-form: "Returning Series", "FINISHED"…).
  status          String?
  genres          String[]
  // Average minutes per episode (series/anime) or the film's runtime; null until
  // captured from the source. Used by the stats aggregation for watch time.
  runtimeMin      Int?
  // 18+ title (TMDB `adult` movies, AniList hentai). Restricted per-account.
  isAdult         Boolean       @default(false)
  metadata        Json          @default("{}")
  lastSyncedAt    DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  externalIds MediaExternalId[]
  seasons     Season[]
  entries     LibraryEntry[]
}

model MediaExternalId {
  id          String         @id @default(cuid())
  mediaItemId String
  source      ExternalSource
  externalId  String
  // The owning MediaItem's type, denormalised here so the unique constraint
  // below can disambiguate it. TMDB numbers movies and TV series in separate
  // ID spaces, so the same externalId can legitimately refer to two different
  // titles depending on type — without `type` in the key, upserting a TMDB
  // series would silently overwrite an unrelated TMDB movie that happens to
  // share the same numeric id (or vice versa).
  type        MediaType

  mediaItem MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  @@unique([source, externalId, type])
  @@index([mediaItemId])
}

model Season {
  id          String  @id @default(cuid())
  mediaItemId String
  number      Int
  title       String?

  mediaItem MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  episodes  Episode[]

  @@unique([mediaItemId, number])
}

model Episode {
  id       String    @id @default(cuid())
  seasonId String
  number   Int
  title    String?
  airDate  DateTime?

  season  Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  watches EpisodeWatch[]

  @@unique([seasonId, number])
}

model LibraryEntry {
  id              String               @id @default(cuid())
  userId          String
  mediaItemId     String
  status          EntryStatus          @default(PLANNED)
  notes           String?
  favorite        Boolean              @default(false)
  startedAt       DateTime?
  finishedAt      DateTime?
  ownershipStatus MediaOwnershipStatus @default(NONE)
  // Free-form detail for DIGITAL/STREAMING (e.g. "Netflix"); null otherwise.
  ownershipSource String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItem MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaItemId])
}

// One row per viewing: watching the same episode twice = two rows (rewatch).
model EpisodeWatch {
  id        String   @id @default(cuid())
  userId    String
  episodeId String
  watchedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([userId, episodeId])
}

// On-demand cache for games, mirroring MediaItem: a game exists here only once
// at least one user references it. Games have no seasons/episodes, so there is
// no progress model — the library entry's status is user-set.
model GameItem {
  id              String     @id @default(cuid())
  canonicalSource GameSource
  title           String
  coverUrl        String?
  backdropUrl     String?
  overview        String?
  releaseDate     DateTime?
  genres          String[]
  platforms       String[]
  // 18+ title (IGDB "Erotic" theme). Restricted per-account, like MediaItem.
  isAdult         Boolean    @default(false)
  metadata        Json       @default("{}")
  lastSyncedAt    DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  externalIds GameExternalId[]
  entries     GameEntry[]
}

model GameExternalId {
  id         String     @id @default(cuid())
  gameItemId String
  source     GameSource
  externalId String

  gameItem GameItem @relation(fields: [gameItemId], references: [id], onDelete: Cascade)

  @@unique([source, externalId])
  @@index([gameItemId])
}

model GameEntry {
  id              String              @id @default(cuid())
  userId          String
  gameItemId      String
  status          GameStatus          @default(BACKLOG)
  notes           String?
  favorite        Boolean             @default(false)
  // Total time played, in minutes. Imported from Steam (playtime_forever);
  // manually editable. No session history yet — this is the running total.
  playtimeMinutes Int                 @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  ownershipStatus GameOwnershipStatus @default(NONE)
  // Free-form detail for DIGITAL/SUBSCRIPTION (e.g. "Steam"); null otherwise.
  ownershipSource String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameItem GameItem     @relation(fields: [gameItemId], references: [id], onDelete: Cascade)
  replays  GameReplay[]

  @@unique([userId, gameItemId])
}

// One row per completed replay, beyond the entry's own first completion —
// mirrors EpisodeWatch's minimalism (a single "when" per viewing/completion).
model GameReplay {
  id          String   @id @default(cuid())
  gameEntryId String
  finishedAt  DateTime @default(now())

  gameEntry GameEntry @relation(fields: [gameEntryId], references: [id], onDelete: Cascade)

  @@index([gameEntryId])
}

// On-demand cache for books, mirroring GameItem: a book exists here only once
// at least one user references it. Books have no chapter model — the library
// entry's status is user-set and page progress lives on the entry.
model BookItem {
  id              String     @id @default(cuid())
  canonicalSource BookSource
  title           String
  authors         String[]
  coverUrl        String?
  overview        String?
  releaseDate     DateTime?
  genres          String[]
  // Number of pages, when the source knows it.
  pageCount       Int?
  // 18+ title (Google Books "MATURE" maturityRating). Restricted per-account,
  // like MediaItem/GameItem.
  isAdult         Boolean    @default(false)
  metadata        Json       @default("{}")
  lastSyncedAt    DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  externalIds BookExternalId[]
  entries     BookEntry[]
}

model BookExternalId {
  id         String     @id @default(cuid())
  bookItemId String
  source     BookSource
  externalId String

  bookItem BookItem @relation(fields: [bookItemId], references: [id], onDelete: Cascade)

  @@unique([source, externalId])
  @@index([bookItemId])
}

model BookEntry {
  id              String              @id @default(cuid())
  userId          String
  bookItemId      String
  status          BookStatus          @default(TO_READ)
  notes           String?
  favorite        Boolean             @default(false)
  // Current reading position, in pages. No session history — running position.
  currentPage     Int                 @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  ownershipStatus BookOwnershipStatus @default(NONE)
  // Free-form detail for DIGITAL/AUDIO (e.g. "Kindle"); null otherwise.
  ownershipSource String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookItem BookItem     @relation(fields: [bookItemId], references: [id], onDelete: Cascade)
  replays  BookReplay[]

  @@unique([userId, bookItemId])
}

// One row per completed reread, beyond the entry's own first completion —
// mirrors EpisodeWatch's minimalism (a single "when" per viewing/completion).
model BookReplay {
  id          String   @id @default(cuid())
  bookEntryId String
  finishedAt  DateTime @default(now())

  bookEntry BookEntry @relation(fields: [bookEntryId], references: [id], onDelete: Cascade)

  @@index([bookEntryId])
}

// On-demand cache for albums, mirroring BookItem: an album exists here only
// once at least one user references it. Albums have no page/chapter model —
// the library entry's status is user-set (binary: to-listen/listened).
model MusicItem {
  id              String      @id @default(cuid())
  canonicalSource MusicSource
  title           String
  artists         String[]
  coverUrl        String?
  releaseDate     DateTime?
  genres          String[]
  // Release-group primary type (Album/EP/Single/Compilation…), informational.
  albumType       String?
  // Number of tracks, when the source knows it.
  trackCount      Int?
  metadata        Json        @default("{}")
  lastSyncedAt    DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  externalIds MusicExternalId[]
  entries     MusicEntry[]
}

model MusicExternalId {
  id          String      @id @default(cuid())
  musicItemId String
  source      MusicSource
  externalId  String

  musicItem MusicItem @relation(fields: [musicItemId], references: [id], onDelete: Cascade)

  @@unique([source, externalId])
  @@index([musicItemId])
}

model MusicEntry {
  id              String               @id @default(cuid())
  userId          String
  musicItemId     String
  status          MusicStatus          @default(TO_LISTEN)
  notes           String?
  favorite        Boolean              @default(false)
  startedAt       DateTime?
  finishedAt      DateTime?
  ownershipStatus MusicOwnershipStatus @default(NONE)
  // Free-form detail for DIGITAL/STREAMING (e.g. "Spotify"); null otherwise.
  ownershipSource String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  musicItem MusicItem @relation(fields: [musicItemId], references: [id], onDelete: Cascade)

  @@unique([userId, musicItemId])
}
