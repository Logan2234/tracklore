{
  "name": "tracklore",
  "version": "0.4.0",
  "private": true,
  "description": "Self-hosted tracker for series, movies, anime — and later games, books and more.",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build:package": "pnpm --filter \"./packages/*\" build",
    "build": "pnpm build:package && pnpm --filter \"./apps/*\" build",
    "test": "pnpm --filter \"./apps/*\" test",
    "lint": "pnpm --recursive --no-bail lint",
    "lint:fix": "pnpm --recursive --no-bail lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "spelunk": "pnpm --filter \"./apps/api\" spelunk",
    "clean": "pnpm --recursive --no-bail run clean",
    "clean:dev": "pnpm --recursive --no-bail clean:dev && rm -rf node_modules docs/*",
    "knip": "knip",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,svelte}": "eslint --fix",
    "*.{json,md,css,yaml,yml}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "knip": "^6.27.0",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
